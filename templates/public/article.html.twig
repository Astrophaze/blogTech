{% extends 'base.html.twig' %}

{% block title %}{{ article.title }} — BlogTech{% endblock %}

{% block body %}
<h1>{{ article.title }}</h1>
<p class="text-muted small">
    Par {{ article.author.username }} — {{ article.createdAt|date('d/m/Y') }}
    {% for category in article.categories %}
        <span class="badge bg-secondary">{{ category.name }}</span>
    {% endfor %}
</p>

<p>{{ article.content }}</p>

<hr>
<h3>Commentaires</h3>

{% for comment in commentaires %}
    <div class="card mb-2">
        <div class="card-body">
            <p class="mb-1">{{ comment.content }}</p>
            <small class="text-muted">Par {{ comment.author.username }} — {{ comment.createdAt|date('d/m/Y') }}</small>
        </div>
    </div>
{% else %}
    <p class="text-muted">Aucun commentaire pour le moment.</p>
{% endfor %}

<a href="{{ path('app_home') }}" class="btn btn-outline-secondary mt-3">Retour à l'accueil</a>
{% endblock %}
