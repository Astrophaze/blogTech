{% extends 'admin/base.html.twig' %}

{% block title %}Articles{% endblock %}

{% block admin_content %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">Articles</h1>
    <a href="{{ path('app_admin_article_new') }}" class="btn btn-primary">Nouvel article</a>
</div>

<table class="table">
    <thead class="table-dark">
        <tr>
            <th>#</th>
            <th>Titre</th>
            <th>Slug</th>
            <th>Statut</th>
            <th>Créé le</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
    {% for article in articles %}
        <tr>
            <td>{{ article.id }}</td>
            <td>{{ article.title }}</td>
            <td>{{ article.slug }}</td>
            <td>{{ article.status.value }}</td>
            <td>{{ article.createdAt ? article.createdAt|date('d/m/Y') : '' }}</td>
            <td>
                <a href="{{ path('app_admin_article_show', {'id': article.id}) }}" class="btn btn-sm btn-outline-primary">Voir</a>
                <a href="{{ path('app_admin_article_edit', {'id': article.id}) }}" class="btn btn-sm btn-outline-secondary">Modifier</a>
            </td>
        </tr>
    {% else %}
        <tr>
            <td colspan="6">Aucun article trouvé.</td>
        </tr>
    {% endfor %}
    </tbody>
</table>
{% endblock %}
