{% extends 'admin/base.html.twig' %}

{% block title %}Commentaires{% endblock %}

{% block admin_content %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">Commentaires</h1>
</div>

<table class="table">
    <thead class="table-dark">
        <tr>
            <th>#</th>
            <th>Contenu</th>
            <th>Auteur</th>
            <th>Article</th>
            <th>Statut</th>
            <th>Date</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
    {% for comment in comments %}
        <tr>
            <td>{{ comment.id }}</td>
            <td>{{ comment.content|slice(0, 60) }}{% if comment.content|length > 60 %}…{% endif %}</td>
            <td>{{ comment.author.username }}</td>
            <td>{{ comment.article.title|slice(0, 30) }}</td>
            <td>
                {% if comment.approved %}
                    <span class="badge bg-success">Approuvé</span>
                {% else %}
                    <span class="badge bg-warning text-dark">En attente</span>
                {% endif %}
            </td>
            <td>{{ comment.createdAt ? comment.createdAt|date('d/m/Y') : '' }}</td>
            <td>
                <a href="{{ path('app_admin_comment_show', {'id': comment.id}) }}" class="btn btn-sm btn-outline-primary">Voir</a>
                <a href="{{ path('app_admin_comment_edit', {'id': comment.id}) }}" class="btn btn-sm btn-outline-secondary">Modérer</a>
            </td>
        </tr>
    {% else %}
        <tr>
            <td colspan="7">Aucun commentaire trouvé.</td>
        </tr>
    {% endfor %}
    </tbody>
</table>
{% endblock %}
