{% extends 'admin/base.html.twig' %}

{% block title %}Modérer le commentaire{% endblock %}

{% block admin_content %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">Modérer le commentaire #{{ comment.id }}</h1>
    <a href="{{ path('app_admin_comment_index') }}" class="btn btn-outline-secondary">Retour</a>
</div>

<table class="table mb-4">
    <tbody>
        <tr><th>Auteur</th><td>{{ comment.author.username }}</td></tr>
        <tr><th>Article</th><td>{{ comment.article.title }}</td></tr>
        <tr><th>Contenu</th><td>{{ comment.content }}</td></tr>
        <tr><th>Date</th><td>{{ comment.createdAt ? comment.createdAt|date('d/m/Y H:i') : '' }}</td></tr>
    </tbody>
</table>

<div
    data-controller="moderation"
    data-moderation-url-value="{{ path('app_admin_comment_toggle_status', {'id': comment.id}) }}"
    data-moderation-approved-value="{{ comment.approved ? 'true' : 'false' }}"
    class="mb-4">
    <button
        data-action="click->moderation#toggle"
        data-moderation-target="bouton"
        class="btn btn-success">
        Approuver
    </button>
</div>

{{ include('admin/comment/_delete_form.html.twig') }}
{% endblock %}
