{% extends 'admin/base.html.twig' %}

{% block title %}Catégories{% endblock %}

{% block admin_content %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">Catégories</h1>
    <a href="{{ path('app_admin_category_new') }}" class="btn btn-primary">Nouvelle catégorie</a>
</div>

<table class="table">
    <thead class="table-dark">
        <tr>
            <th>#</th>
            <th>Nom</th>
            <th>Slug</th>
            <th>Nb articles</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
    {% for category in categories %}
        <tr>
            <td>{{ category.id }}</td>
            <td>{{ category.name }}</td>
            <td>{{ category.slug }}</td>
            <td>{{ category.articles|length }}</td>
            <td>
                <a href="{{ path('app_admin_category_show', {'id': category.id}) }}" class="btn btn-sm btn-outline-primary">Voir</a>
                <a href="{{ path('app_admin_category_edit', {'id': category.id}) }}" class="btn btn-sm btn-outline-secondary">Modifier</a>
            </td>
        </tr>
    {% else %}
        <tr>
            <td colspan="5">Aucune catégorie trouvée.</td>
        </tr>
    {% endfor %}
    </tbody>
</table>
{% endblock %}
