{% extends 'admin/base.html.twig' %}

{% block title %}{{ category.name }}{% endblock %}

{% block admin_content %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">{{ category.name }}</h1>
    <a href="{{ path('app_admin_category_index') }}" class="btn btn-outline-secondary">Retour</a>
</div>

<table class="table">
    <tbody>
        <tr><th>ID</th><td>{{ category.id }}</td></tr>
        <tr><th>Nom</th><td>{{ category.name }}</td></tr>
        <tr><th>Slug</th><td>{{ category.slug }}</td></tr>
    </tbody>
</table>

<a href="{{ path('app_admin_category_edit', {'id': category.id}) }}" class="btn btn-outline-secondary">Modifier</a>
{{ include('admin/category/_delete_form.html.twig') }}
{% endblock %}
